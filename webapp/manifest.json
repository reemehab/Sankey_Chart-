{
    "_version": "1.12.0",
    "sap.app": {
        "id": "ae.test.SACBar",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": { "version": "1.0.0" },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}"
    },
    "sap.ui": {
        "technology": "UI5",
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "rootView": {
            "viewName": "ae.test.SACBar.view.Main",
            "type": "XML",
            "async": true,
            "id": "Main"
        },
        "dependencies": {
            "minUI5Version": "1.65.6",
            "libs": {
                "sap.ui.layout": {},
                "sap.ui.core": {},
                "sap.m": {},
                "sap.viz": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "ae.test.SACBar.i18n.i18n"
                }
            }
        },
        "resources": {
            "css": [{ "uri": "css/style.css" }]
        }
    }
}
