<mvc:View 
    height="100%" 
    controllerName="ae.test.SACBar.controller.Main" 
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:m="sap.m"
    xmlns:form="sap.ui.layout.form" 
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns="sap.m">
    
    <NavContainer id="wizardNavContainer">
        <pages>
            <Page id="wizardContentPage" showHeader="false">
                <content>
                    <ScrollContainer height="100%" vertical="true" horizontal="false">
                        <Wizard id="CreateProductWizard" complete="onWizardCompleted">
                            <WizardStep id="ChartStep" title="Revenue Overview" validated="true">
                                <VBox class="sapUiMediumMargin">
                                    <m:Title text="Monthly Revenue — 2026" level="H3"/>
                                    <viz:VizFrame id="barChart" vizType="bar" width="100%" height="450px">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/sales}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Month" value="{chartModel>month}"/>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Revenue" value="{chartModel>revenue}"/>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Revenue"/>
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </VBox>
                            </WizardStep>
                            <WizardStep id="DetailsStep" title="Details" validated="true">
                                <m:Panel id="selectionPanel" headerText="Selection Details">
                                    <form:SimpleForm editable="false" layout="ResponsiveGridLayout">
                                        <m:Label text="Month"/>
                                        <m:Text id="selectedMonth" text="—"/>
                                        <m:Label text="Revenue"/>
                                        <m:Text id="selectedRevenue" text="—"/>
                                    </form:SimpleForm>
                                </m:Panel>
                            </WizardStep>
                            <WizardStep id="ConfirmStep" title="Confirm" validated="true">
                                <m:Text text="Ready to export data?"/>
                            </WizardStep>
                        </Wizard>
                    </ScrollContainer>
                </content>
                <footer>
                    <OverflowToolbar>
                        <ToolbarSpacer/>
                        <Button text="Next" type="Emphasized" press="onNextStep"/>
                    </OverflowToolbar>
                </footer>
            </Page>
        </pages>
    </NavContainer>
</mvc:View>
